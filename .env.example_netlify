# Netlify Environment Variables
# Copy these values to: Site settings > Build & deploy > Environment > Environment variables

# 1. Database URL (Already set in netlify.toml for build, but good to have)
DATABASE_URL="file:./dev.db"

# 2. NextAuth Configuration (REQUIRED for Login to work)
# Generate a secret: run `openssl rand -base64 32` in terminal or use a random string
NEXTAUTH_SECRET="REPLACE_WITH_A_LONG_RANDOM_STRING"

# The URL of your site
NEXTAUTH_URL="https://YOUR-SITE-NAME.netlify.app"
