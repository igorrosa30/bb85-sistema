// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DB_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

model Prova {
  id          Int @id @default(autoincrement())
  ano         Int
  cargo       String
  tipo_prova  String
  versao      String
  questoes    Questao[]
}

model Questao {
  id              Int @id @default(autoincrement())
  prova_id        Int
  prova           Prova @relation(fields: [prova_id], references: [id])
  numero_base     Int
  materia         String
  subtema         String?
  peso_materia    Float?
  enunciado       String
  imagem_url      String?
  alternativa_A   String
  alternativa_B   String
  alternativa_C   String
  alternativa_D   String
  alternativa_E   String
  alternativa_correta_base String
  comentario      String?
  tipo_pegadinha  String?  // sintaxe_exata | polimorfismo | sql_subconsulta | algoritmo_manual | conceito_direto
  peso_real       Float    @default(1.5)
  is_real_2023    Boolean  @default(false)
  comentario_detalhado String?
  video_url       String?
  mapeamentos     MapeamentoVersao[]
  respostas       RespostaUsuario[]
}

model MapeamentoVersao {
  id              Int @id @default(autoincrement())
  questao_id      Int
  questao         Questao @relation(fields: [questao_id], references: [id])
  versao          String
  mapeamento_json String // JSON storing alternative shuffles
  gabarito_oficial String
}

model RespostaUsuario {
  id              Int @id @default(autoincrement())
  simulado_id     Int?
  simulado        Simulado? @relation(fields: [simulado_id], references: [id])
  questao_id      Int
  questao         Questao @relation(fields: [questao_id], references: [id])
  versao_utilizada String?
  resposta_marcada String
  correta_ou_errada Boolean
  tempo_gasto     Int // seconds
  sintese_erro    String?  // Piazzi: Síntese de 140 chars ao errar
  proxima_revisao DateTime? // Ciclo [0, 1, 3, 7, 15, 30]
  ciclo_revisao   Int      @default(0)
  data            DateTime @default(now())
}

model Simulado {
  id              Int @id @default(autoincrement())
  data            DateTime @default(now())
  tempo_total     Int
  percentual_geral Float
  percentual_materia_json String
  classificacao   String
  tipo            String? // completo, prova, materia, personalizado
  config_json     String? // Stores SimuladoConfig
  respostas       RespostaUsuario[]
}

model UserProfile {
  id              String   @id @default("unico")
  xp              Int      @default(0)
  level           Int      @default(1)
  streak          Int      @default(0)
  lastActivity    DateTime @default(now())
  totalQuestoes   Int      @default(0)
  totalAcertos    Int      @default(0)
}

model Redacao {
  id          String   @id @default(cuid())
  tema        String
  conteudo    String
  correcao    String?
  nota        Int?
  status      String   @default("Rascunho")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}



model NotaRedacao {
  id    Int @id @default(autoincrement())
  data  DateTime @default(now())
  nota  Float
  tema  String?
}
